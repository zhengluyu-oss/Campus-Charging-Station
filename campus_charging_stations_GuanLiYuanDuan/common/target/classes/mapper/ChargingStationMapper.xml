<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tjetc.dao.ChargingStationsMapper">

    <resultMap id="BaseResultMap" type="com.tjetc.entity.core.ChargingStation">
        <id column="station_id" property="stationId"/>
        <result column="station_name" property="stationName"/>
        <result column="location" property="location"/>
        <result column="status" property="status"/>
        <result column="power_rating" property="powerRating"/>
        <result column="price_per_hour" property="pricePerHour"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
    </resultMap>

    <select id="selectLikeName" resultMap="BaseResultMap">
        SELECT * FROM charging_stations
        <where>
            <if test="stationName != null and stationName != ''">
                AND station_name LIKE CONCAT('%', #{stationName}, '%')
            </if>
        </where>
        ORDER BY created_time DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM charging_stations ORDER BY created_time DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM charging_stations WHERE station_id = #{stationId}
    </select>

    <insert id="insert" parameterType="com.tjetc.entity.core.ChargingStation" useGeneratedKeys="true" keyProperty="stationId">
        INSERT INTO charging_stations (
            station_name, location, status,
            power_rating, price_per_hour, created_time, updated_time
        ) VALUES (
                     #{stationName}, #{location}, #{status},
                     #{powerRating}, #{pricePerHour}, #{createdTime}, #{updatedTime}
                 )
    </insert>

    <update id="updateById" parameterType="com.tjetc.entity.core.ChargingStation">
        UPDATE charging_stations
        <set>
            <if test="stationName != null">station_name = #{stationName},</if>
            <if test="location != null">location = #{location},</if>
            <if test="status != null">status = #{status},</if>
            <if test="powerRating != null">power_rating = #{powerRating},</if>
            <if test="pricePerHour != null">price_per_hour = #{pricePerHour},</if>
            <if test="updatedTime != null">updated_time = #{updatedTime},</if>
        </set>
        WHERE station_id = #{stationId}
    </update>

    <delete id="deleteById">
        DELETE FROM charging_stations WHERE station_id = #{stationId}
    </delete>

    <select id="selectByLocation" resultMap="BaseResultMap">
        SELECT * FROM charging_stations WHERE location = #{location}
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM charging_stations WHERE status = #{status}
    </select>

</mapper>