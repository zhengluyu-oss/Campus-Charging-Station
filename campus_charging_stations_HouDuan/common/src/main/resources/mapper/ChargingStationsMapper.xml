<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tjetc.dao.ChargingStationsMapper">

    <!-- 保留你原有的基础结果映射（已包含完整字段，无需修改） -->
    <resultMap id="BaseResultMap" type="com.tjetc.entity.core.ChargingStation">
        <id column="station_id" property="stationId" />
        <result column="station_name" property="stationName" />
        <result column="location" property="location" />
        <result column="status" property="status" />
        <result column="power_rating" property="powerRating" />
        <result column="price_per_hour" property="pricePerHour" />
        <result column="created_time" property="createdTime" />
        <result column="updated_time" property="updatedTime" />
    </resultMap>

    <!-- 保留你原有的按名称模糊查询（带非空判断、倒序排序，无需修改） -->
    <select id="selectLikeName" resultMap="BaseResultMap">
        SELECT * FROM charging_stations
        <where>
            <if test="stationName != null and stationName != ''">
                station_name LIKE concat('%', #{stationName}, '%')
            </if>
        </where>
        ORDER BY created_time DESC
    </select>

    <!-- 新增：按位置精确查询（与原有风格保持一致，带非空判断、统一倒序排序） -->
    <select id="selectByLocation" resultMap="BaseResultMap">
        SELECT * FROM charging_stations
        <where>
            <if test="location != null and location != ''">
                location = #{location}
            </if>
        </where>
        ORDER BY created_time DESC
    </select>

    <!-- 新增：按状态精确查询（与原有风格保持一致，带非空判断、统一倒序排序） -->
    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM charging_stations
        <where>
            <if test="status != null">
                status = #{status}
            </if>
        </where>
        ORDER BY created_time DESC
    </select>
    <sql id="Base_Column_List">
        station_id, station_name, location, status, price_per_hour, type, power_rating
    </sql>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT *
        FROM charging_stations
    </select>


    <update id="updateChargingStationStatus">
            update charging_stations
            set status = 1
            where station_id = #{stationId}
    </update>

    <update id="stopUpdateChargingStationStatus">
        update charging_stations
        set status = 0
        where station_id = #{stationId}
    </update>

    <update id="updateChargingStationStatusAndTime">
        update charging_stations
        set status = 1
        where station_id = #{stationId}
    </update>

</mapper>